# ────────────────────────────────────────────────
#  Environnement
# ────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/gameproject/public

# ────────────────────────────────────────────────
#  Supabase
# ────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Bucket Storage pour jaquettes / logos IGDB (créer dans Supabase → Storage, politique lecture publique)
SUPABASE_STORAGE_BUCKET_IGDB=igdb-assets

# Connexion directe PostgreSQL (Supabase → Settings → Database)
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password-here
# Optionnel : connection pooler (port 6543)
# DB_HOST=aws-0-eu-west-3.pooler.supabase.com
# DB_PORT=6543
# DB_USER=postgres.xxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────
#  Sessions
# ────────────────────────────────────────────────
SESSION_NAME=gameproject_session
SESSION_LIFETIME=604800

# ────────────────────────────────────────────────
#  Cloudflare Turnstile
#  Clés de test (always pass) : gardez-les en dev, remplacez en prod
# ────────────────────────────────────────────────
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# En dev : true = utiliser les vraies clés Cloudflare (domaine autorisé dans le dashboard)
# TURNSTILE_USE_REAL_IN_DEV=false
# Ne pas envoyer l’IP au siteverify (recommandé derrière proxy) sauf si besoin :
# TURNSTILE_VERIFY_REMOTEIP=false

# ────────────────────────────────────────────────
#  Logging
# ────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_FILE_PATH=../storage/logs/app.log

# ────────────────────────────────────────────────
#  IGDB (sync)
# ────────────────────────────────────────────────
IGDB_CLIENT_ID=your-igdb-client-id
IGDB_CLIENT_SECRET=your-igdb-client-secret

# Cache des réponses IGDB (secondes) — 86400 = 24h
IGDB_CACHE_TTL=86400
# IGDB_CACHE_DIR → chemin absolu calculé par le code. Ne pas mettre de chemin relatif ici.
# Exemple si vous voulez forcer : IGDB_CACHE_DIR=/var/www/gameproject/storage/cache/igdb

# Images IGDB :
# - igdb     : ne stocke rien, on sert uniquement les URLs IGDB
# - supabase : upload WebP vers Supabase Storage (recommandé si vous voulez un cache)
# - local    : enregistre les WebP dans storage/images/igdb
IGDB_IMAGES_TARGET=igdb
# IGDB_IMAGES_PATH → chemin absolu calculé par le code. Ne pas mettre de chemin relatif ici.
IGDB_WEBP_QUALITY=80

# Rate limiting (requêtes/seconde — limite IGDB = 4 req/s)
IGDB_RATE_LIMIT=4

# Téléchargements d'images en parallèle par lot
IGDB_DOWNLOAD_CONCURRENT=20

# Circuit breaker — échecs consécutifs avant ouverture
IGDB_CB_THRESHOLD=3
# Délai (secondes) avant passage en HALF-OPEN
IGDB_CB_TIMEOUT=3600

# Retry synchronisation cron — nombre max de tentatives
IGDB_SYNC_MAX_RETRIES=24
