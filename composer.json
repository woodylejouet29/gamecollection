{
    "name": "gameproject/site-collection",
    "description": "Site de collection de jeux vidéo",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.8",
        "phpoffice/phpspreadsheet": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "suggest": {
        "ext-zip": "Cache IGDB un fichier par année (storage/cache/igdb/years/YYYY.zip)"
    }
}
