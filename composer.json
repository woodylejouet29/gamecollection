{
    "name": "playshelf/site",
    "description": "PlayShelf — site de collection de jeux vidéo",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.8",
        "phpoffice/phpspreadsheet": "^2.1",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-zstd": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "suggest": {
        "ext-zip": "Cache IGDB un fichier par année (storage/cache/igdb/years/YYYY.zip)",
        "ext-zstd": "Compression synopsis (synopsis_zstd) + script scripts/migrate_synopsis_zstd.php"
    }
}
